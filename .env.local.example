# ---------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# On Windows PowerShell:   Copy-Item .env.local.example .env.local
# On Windows CMD:          copy .env.local.example .env.local
# ---------------------------------------------------------------

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string (for Drizzle migrations).
# Find it in Supabase -> Project Settings -> Database -> Connection string (URI).
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URL (used to build Stripe success/cancel URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
